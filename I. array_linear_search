#include <stdio.h>

int linearSearch(int arr[], int n, int key) {
for (int i = 0; i < n; i++) {
if (arr[i] == key) {
return i;
}
}
return -1;
}

int main() {
int arr[] = {10, 40, 25, 90, 15};
int n = sizeof(arr) / sizeof(arr[0]);
int key = 90;
int index = linearSearch(arr, n, key);
if (index != -1)

printf("Found %d at index %d\n", key, index);
else
printf("%d not found\n", key);

return 0;
}
